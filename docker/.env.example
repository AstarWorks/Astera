# Astera local-dev environment.
# Copy this file to `.env` (same directory) and adjust as needed:
#     cp docker/.env.example docker/.env
# `.env` is git-ignored; never commit real secrets.

# PostgreSQL superuser password for the local stack. Used by both the
# `postgres` service and the Paper plugin's JDBC client.
POSTGRES_PASSWORD=astera

# RCON password for the Paper server (port 25575).
RCON_PASSWORD=astera
